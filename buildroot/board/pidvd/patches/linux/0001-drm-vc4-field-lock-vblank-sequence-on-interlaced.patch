From: PiDVD <pidvd@localhost>
Subject: [PATCH] drm/vc4: log continuous vblank-count parity at interlaced
 enable (field-dominance reference; no normalization/lock)

Measurement across 16 plays showed the continuous DRM vblank counter parity
perfectly predicts physical field dominance, while HVS FRCNT parity does not.
The prior field-lock normalized the counter at each modeset and locked it to
FRCNT, both of which DESTROY this reference. Reduce to a read-only log of the
continuous parity at the first interlaced vblank; the userspace player aligns
page flips to this counter via its field_parity knob, so leaving the counter
raw and continuous makes a single field_parity choice hold across modesets.

--- a/drivers/gpu/drm/vc4/vc4_drv.h
+++ b/drivers/gpu/drm/vc4/vc4_drv.h
@@ -653,6 +653,15 @@
 	 * access to that value.
 	 */
 	unsigned int current_hvs_channel;
+
+	/*
+	 * PiDVD: armed at interlaced enable; the first interlaced vblank
+	 * logs the continuous DRM vblank-count parity (the measured
+	 * field-dominance predictor) and clears this. No counter
+	 * normalization or FRCNT lock -- the raw continuous parity is what
+	 * the player aligns page flips to via field_parity.
+	 */
+	bool field_anchor_pending;
 };
 
 #define to_vc4_crtc(_crtc)					\
--- a/drivers/gpu/drm/vc4/vc4_crtc.c
+++ b/drivers/gpu/drm/vc4/vc4_crtc.c
@@ -696,6 +696,10 @@
 	CRTC_WRITE(PV_V_CONTROL,
 		   CRTC_READ(PV_V_CONTROL) | PV_VCONTROL_VIDEN);
 
+	/* PiDVD: mark the next interlaced vblank as the post-enable anchor. */
+	if (new_state->adjusted_mode.flags & DRM_MODE_FLAG_INTERLACE)
+		vc4_crtc->field_anchor_pending = true;
+
 	if (vc4_encoder->post_crtc_enable)
 		vc4_encoder->post_crtc_enable(encoder, state);
 
@@ -878,6 +882,25 @@
 		vc4_encoder->vblank(encoder);
 
 	drm_crtc_handle_vblank(&crtc->base);
+
+	/*
+	 * PiDVD: log the continuous DRM vblank-count parity at the first
+	 * interlaced vblank after enable. Measurement (16/16 plays) showed
+	 * this parity predicts physical field dominance; the player aligns
+	 * page flips to it via field_parity. READ-ONLY: deliberately no
+	 * counter normalization and no FRCNT lock -- FRCNT parity is not a
+	 * predictor and locking to it corrupts this reference.
+	 */
+	if (crtc->field_anchor_pending && crtc->base.state &&
+	    (crtc->base.state->adjusted_mode.flags & DRM_MODE_FLAG_INTERLACE)) {
+		u64 seq = drm_crtc_vblank_count(&crtc->base);
+
+		crtc->field_anchor_pending = false;
+		drm_info(crtc->base.dev,
+			 "pidvd-fieldlock: anchor seq=%llu par=%u\n",
+			 (unsigned long long)seq, (unsigned)(seq & 1));
+	}
+
 	vc4_crtc_handle_page_flip(crtc);
 }
 
