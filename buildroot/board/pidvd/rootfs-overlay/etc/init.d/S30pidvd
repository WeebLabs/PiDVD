#!/bin/sh
# PiDVD appliance launcher: the player's picker UI owns the whole flow —
# attract screen until a USB drive appears (it mounts/unmounts the drive
# itself), browse, playback, back to browse. We just launch it.

# Boot messages go to /dev/console (serial) only — never the CRT, which the
# player owns. Mirroring to /dev/tty1 used to flash through on the display.
msg() { printf "%s\n" "$1"; }

case "$1" in
  start)
    # exfat is the expected drive format (FAT32 can't hold DVD9 ISOs)
    modprobe exfat 2>/dev/null
    ip=$(ip -4 addr show eth0 2>/dev/null | sed -n 's/.*inet \([0-9.]*\).*/\1/p')
    [ -n "$ip" ] && msg "PiDVD: network $ip"
    msg "PiDVD: boot $(cut -d. -f1 /proc/uptime)s"
    pidvd-player --ui > /dev/console 2>&1 &
    ;;
  stop)
    killall pidvd-player 2>/dev/null
    ;;
  *)
    echo "Usage: $0 {start|stop}"
    ;;
esac
